---
import Layout from "../layout.astro";
import Socials from "../socials.astro";
---

<Layout title="Hire Bogdan Chadkin - Software Engineer">
  <header class="header">
    <h1 class="name" style="display: table; view-transition-name: name;">
      Bogdan Chadkin
    </h1>
    <div class="contact">
      <a href="mailto:me@trysound.io" class="contact-link">me@trysound.io</a>
      <span class="divider">|</span>
      <a
        href="https://github.com/TrySound"
        target="_blank"
        rel="noopener noreferrer"
        class="contact-link">GitHub</a
      >
      <span class="divider">|</span>
      <a
        href="https://linkedin.com/in/bogdan-chadkin"
        target="_blank"
        rel="noopener noreferrer"
        class="contact-link">LinkedIn</a
      >
      <span class="divider">|</span>
      <a
        href="https://t.me/iamtrysound"
        target="_blank"
        rel="noopener noreferrer"
        class="contact-link">Telegram</a
      >
      <span class="divider">|</span>
      <span class="timezone">US & EU Timezones</span>
    </div>
  </header>

  <main>
    <section class="section">
      <p class="summary">
        Senior full-stack engineer specialising in build tools, performance, and
        user experience. Over 13 years of experience building products across
        industrial software, freelance platforms, and design tools. Core
        contributor to major JS ecosystem tools with tens of millions of monthly
        downloads. Created Engramma, maintained SVGO (22k stars), Rollup (26k
        stars) and PostCSS (29k stars).
      </p>
    </section>

    <section class="section">
      <h2 class="section-title">What I'm Best For</h2>
      <ul class="bestfor-list">
        <li>Build tooling and compiler pipelines for modern web apps</li>
        <li>Performance optimization across build and runtime paths</li>
        <li>User experience and visual editor UX</li>
        <li>Design systems, tokens, and scalable component architecture</li>
        <li>Developer experience and engineering velocity improvements</li>
      </ul>
    </section>

    <section class="section">
      <h2 class="section-title">Notable Open Source Work</h2>
      <div class="opensource-grid">
        <article class="card">
          <a
            class="card-link"
            target="_blank"
            href="https://github.com/TrySound/engramma"
          >
            <h3 class="card-title">Engramma (author)</h3>
            <span class="card-subtitle">2025–present</span>
            <p class="card-description">
              Web application for generating style guides and managing design
              tokens.
            </p>
          </a>
        </article>
        <article class="card">
          <a
            class="card-link"
            target="_blank"
            href="https://github.com/svg/svgo"
          >
            <h3 class="card-title">SVGO (maintainer)</h3>
            <span class="card-subtitle">2021–2023</span>
            <p class="card-description">
              Popular SVG optimizer. Rebuilt plugin system, reduced package size
              by 40%, improved stability.
            </p>
          </a>
        </article>
        <article class="card">
          <a
            class="card-link"
            target="_blank"
            href="https://github.com/rollup/rollup"
          >
            <h3 class="card-title">Rollup (contributor)</h3>
            <span class="card-subtitle">2015–2018</span>
            <p class="card-description">
              Next-generation ES module bundler. Implemented persistent caching
              (60% faster rebuilds), improved tree-shaking, contributed into
              plugin ecosystem.
            </p>
          </a>
        </article>
        <article class="card">
          <a
            class="card-link"
            target="_blank"
            href="https://github.com/postcss/postcss"
          >
            <h3 class="card-title">PostCSS ecosystem</h3>
            <span class="card-subtitle">2015–2016</span>
            <p class="card-description">
              A tool for transforming CSS with JavaScript CSS used by thousands
              projects. Core contributor, co-authored cssnano minifier, created
              postcss-value-parser.
            </p>
          </a>
        </article>
      </div>
    </section>

    <section class="section">
      <h2 class="section-title">Technical Expertise</h2>
      <div class="expertise-grid">
        <article class="card">
          <h3 class="card-title">Languages</h3>
          <p class="card-description">
            TypeScript, JavaScript, CSS, HTML, SQL, SVG
          </p>
        </article>
        <article class="card">
          <h3 class="card-title">Frameworks</h3>
          <p class="card-description">
            React, Next.js, Svelte, Node.js, Hono, Remix, Astro
          </p>
        </article>
        <article class="card">
          <h3 class="card-title">Databases</h3>
          <p class="card-description">PostgreSQL, SQLite, Hasura</p>
        </article>
        <article class="card">
          <h3 class="card-title">Cloud & DevOps</h3>
          <p class="card-description">
            GCP, Cloudflare, Vercel, Docker, Terraform, GitHub Actions
          </p>
        </article>
        <article class="card">
          <h3 class="card-title">Tools & Others</h3>
          <p class="card-description">GraphQL, Git</p>
        </article>
      </div>
    </section>

    <section class="section">
      <h2 class="section-title">Professional Experience</h2>

      <article class="experience-item">
        <div class="experience-header">
          <h3 class="company"><a href="https://webstudio.is">Webstudio</a></h3>
          <span class="role">Software Engineer</span>
          <span class="date">2022–2026</span>
        </div>
        <p class="company-tagline">
          Open-source visual website builder with full CSS control
        </p>
        <ul class="experience-list">
          <li>
            Built core platform features like <strong
              >CSS spec-based style engine</strong
            >, HTML validation, visual CMS integration, tokens and variables for
            design system workflow
          </li>
          <li>
            Created <strong>CLI</strong> to generate websites for our Cloud and self
            hosting on Vercel, Netlify and Docker
          </li>
          <li>
            Led UI building for <strong>Inception AI</strong> (companion product)
            generating production-grade code from design exploration
          </li>
          <li>
            Scaled community engagement by resolving technical issues and
            gathering feedback to shape product roadmap
          </li>
        </ul>
      </article>

      <article class="experience-item">
        <div class="experience-header">
          <h3 class="company">
            <a href="https://realadvisor.ch/en">RealAdvisor</a>
          </h3>
          <span class="role">Software Engineer</span>
          <span class="date">2017–2022</span>
        </div>
        <p class="company-tagline">
          Swiss real-estate platform (property valuations, agent matching)
        </p>
        <ul class="experience-list">
          <li>
            Architected <strong>custom auth system</strong> with multi-level permissions,
            supporting over 130 enterprise partners, enabling B2B expansion
          </li>
          <li>
            Led a <strong>3-month TypeScript migration</strong> of a large codebase
            of UI and GraphQL server codebase, reducing manual testing and improving
            release time by 30%
          </li>
          <li>
            Shipped <strong>valuation tools and lead routing workflows</strong> used
            by 10K agents
          </li>
          <li>
            Migrated database-centric API to <strong>Hasura</strong>,
            modernizing data layer architecture
          </li>
          <li>Mentored engineers and onboarded new team members</li>
        </ul>
      </article>

      <article class="experience-item">
        <div class="experience-header">
          <h3 class="company">Siemens</h3>
          <span class="role">Software Engineer</span>
          <span class="date">2015–2017</span>
        </div>
        <p class="company-tagline">Industrial monitoring systems</p>
        <ul class="experience-list">
          <li>
            Built <strong>real-time telemetry dashboards</strong> for gas turbine
            sensors with live alarms and diagnostics
          </li>
          <li>
            Developed <strong>water communications monitoring UIs</strong> deployed
            to 50+ facilities
          </li>
          <li>
            Modernized build pipeline by integrating modern bundlers,
            significantly improving developer experience and iteration speed
          </li>
        </ul>
      </article>

      <article class="experience-item">
        <div class="experience-header">
          <h3 class="company">Freelance</h3>
          <span class="role">Frontend Developer</span>
          <span class="date">2012–2015</span>
        </div>
        <ul class="experience-list">
          <li>
            Delivered <strong>15+ responsive web applications</strong> for startups
            and agencies
          </li>
        </ul>
      </article>
    </section>

    <section class="section cta-section">
      <h2 class="cta-title">Let's Build Something Great</h2>
      <p class="cta-text">
        Available for full-time, B2B freelance projects and technical consulting
        engagements. I help teams build fast, accessible user interfaces and
        scalable frontend architecture.
      </p>
      <a href="mailto:me@trysound.io" class="cta-button">Get in Touch</a>
    </section>
  </main>

  <footer class="footer">
    <a href="/" class="footer-backlink">← Back to home</a>
    <Socials />
  </footer>
</Layout>

<style>
  .header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .name {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }

  .contact {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    font-size: 0.95rem;
  }

  .contact-link {
    font-weight: 500;
  }

  .divider {
    color: var(--text-muted);
    font-weight: 300;
  }

  .timezone {
    color: var(--text-secondary);
  }

  .section {
    margin-bottom: 2.5rem;
  }

  .summary {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--text-secondary);
  }

  .bestfor-list {
    color: var(--text-secondary);
    padding-left: 1.25rem;
    line-height: 1.6;
  }

  .bestfor-list li {
    margin-bottom: 0.5rem;
  }

  .opensource-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  }

  .expertise-grid {
    display: grid;
    gap: 1.25rem;
  }

  .experience-item {
    margin-bottom: 2.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--border);
  }

  .experience-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
    margin-bottom: 0;
  }

  .experience-header {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    align-items: baseline;
    margin-bottom: 0.5rem;
  }

  .company {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .role {
    color: var(--text-secondary);
  }

  .date {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .company-tagline {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin-bottom: 1rem;
    font-style: italic;
  }

  .experience-list {
    color: var(--text-secondary);
    padding-left: 1.25rem;
  }

  .experience-list li {
    margin-bottom: 0.5rem;
    line-height: 1.6;
  }

  .card-proof {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin-top: 0.5rem;
  }

  strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  @media print {
    .section {
      break-inside: avoid;
    }

    .contact {
      display: grid;
    }

    .divider {
      display: none;
    }

    .header {
      margin-bottom: 1.5rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid #cccccc;
    }

    .name {
      font-size: 2rem;
      color: #000000;
    }

    .section {
      margin-bottom: 1.5rem;
    }

    .section-title {
      color: #000000;
      border-bottom: 2px solid #000000;
      margin-bottom: 1rem;
    }

    .summary {
      color: #333333;
    }

    .bestfor-list {
      color: #333333;
    }

    .opensource-grid {
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
    }

    .card {
      background: transparent;
      border: none;
      padding: 0.5rem 0;
      break-inside: avoid;
    }

    .card:has(.card-link) {
      padding: 0;
    }

    .card-link {
      padding: 0.5rem 0;
      gap: 0.25rem;
    }

    .card-title {
      color: #000000;
      font-size: 1.1rem;
    }

    .card-subtitle {
      color: #666666;
    }

    .card-description {
      color: #333333;
    }

    .card-proof {
      color: #666666;
    }

    .expertise-grid {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .experience-item {
      margin-bottom: 1.5rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid #cccccc;
      break-inside: avoid;
    }

    .company {
      color: #000000;
    }

    .role {
      color: #333333;
    }

    .date {
      color: #666666;
    }

    .company-tagline {
      color: #666666;
    }

    .experience-list {
      color: #333333;
    }

    strong {
      color: #000000;
    }

    .footer {
      display: none;
    }
  }
</style>
